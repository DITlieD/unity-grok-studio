{
  "mcpServers": {
    "unity": {
      "command": "uvx",
      "args": [
        "--from",
        "mcpforunityserver==10.1.0",
        "mcp-for-unity"
      ]
    },
    "blender-gen": {
      "command": "bash",
      "args": [
        "${GROK_PLUGIN_ROOT}/mcp-wrappers/blender-gen.sh"
      ]
    },
    "vision-check": {
      "command": "bash",
      "args": [
        "${GROK_PLUGIN_ROOT}/mcp-wrappers/vision-check.sh"
      ]
    }
  }
}
