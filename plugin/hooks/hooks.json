{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[unity-grok-studio] ROOT=${UNITY_GROK_ROOT:-unset} plugin=${GROK_PLUGIN_ROOT:-unset}. Prefer free-auto + FreeLLMAPI vision. Run ./scripts/doctor.sh.\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$GROK_PLUGIN_ROOT/hooks/bin/vision-predescribe.sh\"",
            "timeout": 90
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|run_terminal_command|Write|Edit|Read|Delete|MultiEdit|search_replace|read_file",
        "hooks": [
          {
            "type": "command",
            "command": "\"$GROK_PLUGIN_ROOT/hooks/bin/lia-pretool.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
