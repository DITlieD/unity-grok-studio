{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unity-grok.local/sfx/layer_plan.schema.json",
  "title": "SfxLayerPlan",
  "type": "object",
  "required": ["version", "name", "layers", "family", "target"],
  "properties": {
    "version": { "type": "integer", "minimum": 0 },
    "name": { "type": "string" },
    "profile": { "type": "string", "default": "impact" },
    "seed": { "type": "integer", "default": 0 },
    "event_map": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["t_ms"],
        "properties": {
          "t_ms": { "type": "number" },
          "label": { "type": "string" }
        }
      }
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "source"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["transient", "body", "texture", "sub", "tail", "sweetener", "debris"]
          },
          "source": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["kind"],
                "properties": {
                  "kind": { "enum": ["file", "dsp"] },
                  "path": { "type": "string" },
                  "dsp": { "type": "string" },
                  "params": { "type": "object" }
                }
              }
            ]
          },
          "event_index": { "type": "integer", "default": 0 },
          "offset_ms": { "type": "number", "default": 0 },
          "gain_db": { "type": "number", "default": 0 },
          "fade_in_ms": { "type": "number", "default": 0 },
          "fade_out_ms": { "type": "number", "default": 0 },
          "pitch_cents": {
            "type": "number",
            "minimum": -150,
            "maximum": 150,
            "default": 0
          },
          "hp_hz": { "type": ["number", "null"] },
          "lp_hz": { "type": ["number", "null"] }
        }
      }
    },
    "family": {
      "type": "object",
      "required": ["variant_count"],
      "properties": {
        "variant_count": { "type": "integer", "minimum": 1, "maximum": 32 },
        "jitter": {
          "type": "object",
          "properties": {
            "gain_db": { "type": "number", "default": 0.5 },
            "pitch_cents": { "type": "number", "default": 20 },
            "offset_ms": { "type": "number", "default": 5 }
          }
        },
        "lock_transient_pitch": { "type": "boolean", "default": true }
      }
    },
    "target": {
      "type": "object",
      "properties": {
        "peak_dbfs": { "type": "number", "default": -1.0 },
        "sample_rate": { "type": "integer", "default": 48000 },
        "channels": { "type": "integer", "default": 1 },
        "duration_s": { "type": ["number", "null"] }
      }
    }
  }
}
