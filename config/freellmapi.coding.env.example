# FreeLLMAPI .env fragment for a coding-agent profile (not the full free catalog).
# Copy into your FreeLLMAPI deployment .env and restart.

PORT=3001
HOST=::
# HOST_BIND=127.0.0.1   # prefer localhost-only for coworkers

# Mid-session model switch continuity (does NOT transfer hidden reasoning)
FREELLMAPI_CONTEXT_HANDOFF=on_model_switch

# Generate once: openssl rand -hex 32
ENCRYPTION_KEY=replace-me-with-openssl-rand-hex-32

# Proxy safety
PROXY_RATE_LIMIT_RPM=120

# ---------------------------------------------------------------------------
# Coding profile (create in FreeLLMAPI dashboard after first boot):
#   - Strategy: priority or reliable
#   - Enable ONLY models with: structured tools + ≥32k context + code editing
#   - Suggested chain: best free coder → Qwen Coder / Devstral-class → strong
#     tool model → fast small coder
#   - Avoid fusion as the normal Grok agent model (quota + latency)
#   - Grok context_window must be the SMALLEST window in this chain
# ---------------------------------------------------------------------------
