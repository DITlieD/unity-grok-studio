# Copy to .env or export in shell (never commit real secrets)
export UNITY_GROK_ROOT="$(pwd)"
export GROK_PLUGIN_ROOT="$UNITY_GROK_ROOT/plugin"
export SFX_LIB="$UNITY_GROK_ROOT/sfx_library"
# FreeLLMAPI / OpenAI-compatible
export FREELLM_API_KEY=freellmapi-local
export FREELLM_BASE_URL=http://127.0.0.1:3001/v1
export VISION_MODEL=auto
# Optional
# export MESHY_API_KEY=
# export FREESOUND_CLIENT_ID=
# export FREESOUND_API_KEY=
# export UNITY_PROJECT=/path/to/YourUnityProject
# export BLENDER_BIN=blender
